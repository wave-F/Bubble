{
  "name": "haptic-test-app",
  "version": "1.0.0",
  "private": true,
  "description": "HapticForWeb test app for iOS",
  "scripts": {
    "copy-web": "rm -rf www && mkdir -p www && cp ../index.html ../haptic-module.js www/ && cp -r ../assets www/",
    "sync": "npm run copy-web && npx cap sync ios",
    "open": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "capacitor-haptic-plugin": "file:../../HapticForWeb/capacitor-haptic-plugin"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
